{
  "name": "vulflare",
  "private": true,
  "scripts": {
    "dev:worker": "wrangler dev",
    "dev:web": "pnpm --filter @vulflare/web dev",
    "build:web": "pnpm --filter @vulflare/web build",
    "deploy:worker": "wrangler deploy --env production",
    "deploy:web": "pnpm --filter @vulflare/web build && wrangler pages deploy apps/web/dist --project-name vulflare",
    "db:migrate": "wrangler d1 migrations apply vulflare-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply vulflare-db --env production --remote",
    "type-check": "pnpm run -r type-check",
    "test": "pnpm run -r test",
    "test:worker": "pnpm --filter @vulflare/worker test",
    "test:web": "pnpm --filter @vulflare/web test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format:check": "biome format --check .",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@cloudflare/vitest-pool-workers": "^0.14.8",
    "@cloudflare/workers-types": "^4.20260417.1",
    "msw": "^2.13.4",
    "typescript": "^5.7.0",
    "vite-plus": "^0.1.18",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "esbuild": ">=0.25.0",
      "undici": ">=7.24.0",
      "picomatch": ">=4.0.4",
      "follow-redirects": ">=1.16.0",
      "vite-plus": ">=0.1.17"
    }
  }
}
